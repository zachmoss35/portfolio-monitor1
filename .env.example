# SMTP email settings (required for weekday email delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=recipient@example.com

# Optional: NewsAPI key for richer news (falls back to Yahoo Finance news)
NEWS_API_KEY=

# Optional: SEC EDGAR user-agent (required by SEC — use your name + email)
SEC_USER_AGENT=PortfolioMonitor your-email@example.com

# Optional: OpenAI for AI analyst summaries (disabled if key is absent)
OPENAI_API_KEY=

# Report tuning
USE_AI_SUMMARY=false
MAX_NEWS_PER_TICKER=5
EARNINGS_LOOKAHEAD_DAYS=30
MATERIAL_MOVE_THRESHOLD=0.05

# Timezone — set on VPS to America/New_York (see deploy/README.md)
TZ=America/New_York
REPORT_TIMEZONE=America/New_York

# Cron / scheduler time (6:00 AM Eastern for VPS cron)
EMAIL_HOUR=6
EMAIL_MINUTE=0
